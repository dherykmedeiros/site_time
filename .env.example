# Transaction pooler (porta 6543) – usado pelo Prisma em runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexão direta (porta 5432) – usada pelo Prisma para migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Supabase Storage (S3-compatible endpoint)
# Exemplo de endpoint: https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_STORAGE_BUCKET="uploads"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
