generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────

enum Role {
  ADMIN
  PLAYER
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  LEFT_BACK
  RIGHT_BACK
  MIDFIELDER
  DEFENSIVE_MIDFIELDER
  FORWARD
  LEFT_WINGER
  RIGHT_WINGER
}

enum PlayerStatus {
  ACTIVE
  INACTIVE
}

enum AvailabilityFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY_OPTIONAL
}

enum AvailabilityLevel {
  AVAILABLE
  PREFERABLE
  UNAVAILABLE
}

enum MatchType {
  FRIENDLY
  CHAMPIONSHIP
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MatchLineupRole {
  STARTER
  BENCH
}

enum MatchLineupFormation {
  FOUR_FOUR_TWO
  FOUR_THREE_THREE
  FOUR_TWO_THREE_ONE
  THREE_FIVE_TWO
  THREE_FOUR_THREE
  FIVE_THREE_TWO
  FOUR_ONE_FOUR_ONE
}

enum MatchLineupBlockPreset {
  DEEP
  BALANCED
  HIGH
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum FriendlyRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  MEMBERSHIP
  FRIENDLY_FEE
  VENUE_RENTAL
  REFEREE
  EQUIPMENT
  OTHER
}

enum AchievementType {
  HAT_TRICK
  TOP_SCORER_ROUND
  VETERAN
  ASSIST_MASTER
  FULL_ATTENDANCE_MONTH
}

enum SeasonType {
  LEAGUE
  CUP
  TOURNAMENT
}

enum SeasonStatus {
  ACTIVE
  FINISHED
}

enum TeamFieldType {
  GRASS
  SYNTHETIC
  FUTSAL
  SOCIETY
  OTHER
}

enum TeamCompetitiveLevel {
  CASUAL
  INTERMEDIATE
  COMPETITIVE
}

enum OpenMatchSlotStatus {
  OPEN
  BOOKED
  CLOSED
}

// ─── Models ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(PLAYER)
  teamId       String?
  team         Team?    @relation(fields: [teamId], references: [id])
  playerId     String?  @unique
  player       Player?  @relation(fields: [playerId], references: [id])
  pushSubscriptions PushSubscription[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Team {
  id               String              @id @default(cuid())
  name             String
  shortName        String?
  slug             String              @unique
  badgeUrl         String?
  description      String?
  primaryColor     String?
  secondaryColor   String?
  defaultVenue     String?
  city             String?
  region           String?
  fieldType        TeamFieldType?
  competitiveLevel TeamCompetitiveLevel?
  publicDirectoryOptIn Boolean         @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  users            User[]
  players          Player[]
  matches          Match[]
  friendlyRequests FriendlyRequest[]
  transactions     Transaction[]
  inviteTokens     InviteToken[]
  membershipPayments MembershipPayment[]
  seasons          Season[]
  openMatchSlots   OpenMatchSlot[]

  @@map("teams")
}

model Player {
  id           String         @id @default(cuid())
  name         String
  fullName     String?
  position     PlayerPosition
  shirtNumber  Int
  photoUrl     String?
  age          Int?
  phone        String?
  description  String?
  status       PlayerStatus   @default(ACTIVE)
  teamId       String
  team         Team           @relation(fields: [teamId], references: [id])
  user         User?
  rsvps        RSVP[]
  availabilityRules PlayerAvailabilityRule[]
  attendances  MatchAttendance[]
  lineupSelections MatchLineupSelection[]
  matchStats   MatchStats[]
  inviteTokens InviteToken[]
  membershipPayments MembershipPayment[]
  achievements Achievement[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([teamId, shirtNumber])
  @@map("players")
}

model PlayerAvailabilityRule {
  id           String                @id @default(cuid())
  playerId     String
  player       Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int
  frequency    AvailabilityFrequency
  availability AvailabilityLevel
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([playerId])
  @@index([playerId, dayOfWeek])
  @@map("player_availability_rules")
}

model Match {
  id         String      @id @default(cuid())
  date       DateTime
  venue      String
  opponent   String
  opponentBadgeUrl String?
  type       MatchType
  homeScore  Int?
  awayScore  Int?
  isHome     Boolean     @default(true)
  status     MatchStatus @default(SCHEDULED)
  lineupFormation MatchLineupFormation?
  lineupBlockPreset MatchLineupBlockPreset?
  shareToken String      @unique @default(uuid())
  teamId     String
  team       Team        @relation(fields: [teamId], references: [id])
  rsvps      RSVP[]
  checklistItems MatchChecklistItem[]
  attendances MatchAttendance[]
  lineupSelections MatchLineupSelection[]
  matchStats MatchStats[]
  transactions Transaction[]
  positionLimits MatchPositionLimit[]
  seasonId   String?
  season     Season?     @relation(fields: [seasonId], references: [id])
  achievements Achievement[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([teamId])
  @@index([seasonId])
  @@map("matches")
}

model MatchLineupSelection {
  id         String          @id @default(cuid())
  matchId    String
  playerId   String
  role       MatchLineupRole
  sortOrder  Int
  fieldX     Int?
  fieldY     Int?
  match      Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player     Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId, role, sortOrder])
  @@index([playerId])
  @@map("match_lineup_selections")
}

model MatchPositionLimit {
  id         String         @id @default(cuid())
  matchId    String
  match      Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  position   PlayerPosition
  maxPlayers Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @default(now()) @updatedAt

  @@unique([matchId, position])
  @@index([matchId])
  @@map("match_position_limits")
}

model RSVP {
  id          String     @id @default(cuid())
  status      RSVPStatus @default(PENDING)
  playerId    String
  player      Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  respondedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@unique([playerId, matchId])
  @@index([matchId])
  @@index([matchId, status])
  @@map("rsvps")
}

model MatchStats {
  id          String   @id @default(cuid())
  goals       Int      @default(0)
  assists     Int      @default(0)
  yellowCards Int      @default(0)
  redCards    Int      @default(0)
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([playerId, matchId])
  @@index([matchId])
  @@index([playerId])
  @@map("match_stats")
}

model FriendlyRequest {
  id                String                @id @default(cuid())
  requesterTeamName String
  contactEmail      String
  contactPhone      String?
  suggestedDates    String
  suggestedVenue    String?
  proposedFee       Decimal?
  status            FriendlyRequestStatus @default(PENDING)
  rejectionReason   String?
  teamId            String
  team              Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([teamId])
  @@index([teamId, status])
  @@map("friendly_requests")
}

model OpenMatchSlot {
  id         String              @id @default(cuid())
  teamId     String
  date       DateTime
  timeLabel  String?
  venueLabel String?
  notes      String?
  status     OpenMatchSlotStatus @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  team       Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([status, date])
  @@map("open_match_slots")
}

model Transaction {
  id          String              @id @default(cuid())
  type        TransactionType
  amount      Decimal
  description String
  category    TransactionCategory
  date        DateTime
  teamId      String
  matchId     String?
  team        Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  match       Match?              @relation(fields: [matchId], references: [id], onDelete: SetNull)
  membershipPayment MembershipPayment?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([teamId])
  @@index([matchId])
  @@index([teamId, date])
  @@map("transactions")
}

model MatchChecklistItem {
  id        String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  label      String
  isChecked  Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([matchId, sortOrder])
  @@map("match_checklist_items")
}

model MatchAttendance {
  id          String   @id @default(cuid())
  matchId      String
  playerId     String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  present      Boolean  @default(false)
  checkedInAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@map("match_attendances")
}

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(uuid())
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@index([teamId])
  @@index([playerId])
  @@map("invite_tokens")
}

model MembershipPayment {
  id            String       @id @default(cuid())
  playerId      String
  teamId        String
  month         Int
  year          Int
  amount        Decimal      @db.Decimal(10, 2)
  paidAt        DateTime     @default(now())
  transactionId String?      @unique
  player        Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  updatedAt     DateTime     @default(now()) @updatedAt

  @@unique([playerId, month, year])
  @@index([teamId])
  @@index([playerId, teamId])
  @@index([year, month])
  @@map("membership_payments")
}

model Achievement {
  id        String          @id @default(cuid())
  playerId  String
  type      AchievementType
  matchId   String?
  awardedAt DateTime        @default(now())
  player    Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match     Match?          @relation(fields: [matchId], references: [id], onDelete: SetNull)
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([playerId])
  @@index([matchId])
  @@map("achievements")
}

model Season {
  id        String       @id @default(cuid())
  teamId    String
  name      String
  type      SeasonType
  startDate DateTime
  endDate   DateTime?
  status    SeasonStatus @default(ACTIVE)
  team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matches   Match[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([teamId])
  @@index([teamId, status])
  @@map("seasons")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
